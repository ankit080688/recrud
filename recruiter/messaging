<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Messaging & Scheduling — Recrud</title>
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    html { background: #F9FAFB }
    html.dark { background: #111827 }
  </style>
</head>
<body class="min-h-screen text-gray-800 dark:text-gray-200 flex flex-col">
  <!-- Header -->
  <header class="bg-white dark:bg-gray-800 shadow px-6 py-4 flex justify-between items-center">
    <h1 class="text-2xl font-semibold">Recrud</h1>
    <div class="flex items-center space-x-4">
      <button id="theme-toggle" class="p-2 rounded focus:ring-2 focus:ring-indigo-500">
        <svg id="icon-light" class="h-6 w-6 text-yellow-400 hidden" fill="currentColor" viewBox="0 0 20 20">
          <path d="M10 3l1 2 2 .3-1.5 1 .3 2L10 8l-1.8.6.3-2L7 5.3l2-.3 1-2z"/>
        </svg>
        <svg id="icon-dark" class="h-6 w-6 text-gray-200" fill="currentColor" viewBox="0 0 20 20">
          <path d="M17.3 13.3a8 8 0 11-10.6-10.6 8 8 0 0010.6 10.6z"/>
        </svg>
      </button>
      <img src="https://via.placeholder.com/32" alt="Avatar" class="w-8 h-8 rounded-full"/>
    </div>
  </header>

  <main class="flex-1 flex overflow-hidden">
    <!-- Messaging Panel -->
    <aside class="w-1/3 bg-white dark:bg-gray-800 border-r dark:border-gray-700 flex flex-col">
      <!-- Contacts -->
      <div class="p-4 border-b dark:border-gray-700">
        <h2 class="text-lg font-medium">Contacts</h2>
      </div>
      <ul class="flex-1 overflow-auto">
        <li class="px-4 py-3 hover:bg-gray-100 dark:hover:bg-gray-700 cursor-pointer flex items-center">
          <img src="https://via.placeholder.com/32" class="w-8 h-8 rounded-full mr-3" alt="Alice"/>
          <span>Alice Smith</span>
        </li>
        <li class="px-4 py-3 hover:bg-gray-100 dark:hover:bg-gray-700 cursor-pointer flex items-center">
          <img src="https://via.placeholder.com/32" class="w-8 h-8 rounded-full mr-3" alt="Bob"/>
          <span>Bob Johnson</span>
        </li>
        <!-- More contacts... -->
      </ul>
      <!-- New Message Button -->
      <div class="p-4 border-t dark:border-gray-700">
        <button class="w-full px-4 py-2 bg-indigo-600 text-white rounded hover:bg-indigo-700">+ New Message</button>
      </div>
    </aside>

    <!-- Chat & Scheduling -->
    <section class="flex-1 flex flex-col">
      <!-- Chat Header -->
      <div class="bg-white dark:bg-gray-800 border-b dark:border-gray-700 px-6 py-4 flex justify-between items-center">
        <div class="flex items-center space-x-4">
          <img src="https://via.placeholder.com/40" class="w-10 h-10 rounded-full" alt="Alice"/>
          <h2 class="text-xl font-semibold">Alice Smith</h2>
        </div>
        <button class="px-3 py-1 bg-yellow-500 text-white rounded hover:bg-yellow-600 text-sm">Schedule Interview</button>
      </div>

      <div class="flex-1 overflow-hidden flex">
        <!-- Chat Window -->
        <div class="w-2/3 flex flex-col">
          <div id="chat-window" class="flex-1 p-6 overflow-auto space-y-4">
            <div class="flex items-start space-x-3">
              <img src="https://via.placeholder.com/32" class="w-8 h-8 rounded-full" alt="Alice"/>
              <div>
                <p class="bg-gray-100 dark:bg-gray-700 p-3 rounded-lg">Hi there! Are you available for an interview tomorrow?</p>
                <span class="text-xs text-gray-500 dark:text-gray-400">10:02 AM</span>
              </div>
            </div>
            <div class="flex items-start space-x-3 justify-end">
              <div class="text-right">
                <p class="bg-indigo-600 text-white p-3 rounded-lg">Yes, what time works for you?</p>
                <span class="text-xs text-gray-500 dark:text-gray-400">10:05 AM</span>
              </div>
              <img src="https://via.placeholder.com/32" class="w-8 h-8 rounded-full" alt="Me"/>
            </div>
            <!-- More messages... -->
          </div>
          <!-- Composer -->
          <div class="p-4 bg-white dark:bg-gray-800 border-t dark:border-gray-700 flex items-center space-x-3">
            <input id="message-input" type="text" placeholder="Type a message..."
              class="flex-1 px-4 py-2 bg-gray-100 dark:bg-gray-700 border rounded focus:ring-indigo-500 focus:border-indigo-500"/>
            <button id="send-btn" class="px-4 py-2 bg-indigo-600 text-white rounded hover:bg-indigo-700">Send</button>
          </div>
        </div>

        <!-- Scheduling Panel -->
        <div class="w-1/3 bg-white dark:bg-gray-800 border-l dark:border-gray-700 p-6 overflow-auto">
          <h3 class="text-lg font-semibold mb-4">Schedule Interview</h3>
          <form id="schedule-form" class="space-y-4">
            <div>
              <label class="block text-sm font-medium">Date</label>
              <input type="date" required
                class="mt-1 w-full px-3 py-2 bg-gray-100 dark:bg-gray-700 border rounded focus:ring-indigo-500 focus:border-indigo-500"/>
            </div>
            <div>
              <label class="block text-sm font-medium">Time</label>
              <input type="time" required
                class="mt-1 w-full px-3 py-2 bg-gray-100 dark:bg-gray-700 border rounded focus:ring-indigo-500 focus:border-indigo-500"/>
            </div>
            <div>
              <label class="block text-sm font-medium">Method</label>
              <select required
                class="mt-1 w-full px-3 py-2 bg-gray-100 dark:bg-gray-700 border rounded focus:ring-indigo-500 focus:border-indigo-500">
                <option>Video Call</option>
                <option>Phone Call</option>
                <option>In-Person</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium">Notes</label>
              <textarea rows="3"
                class="mt-1 w-full px-3 py-2 bg-gray-100 dark:bg-gray-700 border rounded focus:ring-indigo-500 focus:border-indigo-500"></textarea>
            </div>
            <button type="submit" class="w-full px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700">Send Invite</button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <script>
    // Theme toggle
    const htmlEl = document.documentElement,
          tgl = document.getElementById('theme-toggle'),
          iL = document.getElementById('icon-light'),
          iD = document.getElementById('icon-dark');
    tgl.onclick = () => {
      htmlEl.classList.toggle('dark');
      localStorage.setItem('theme', htmlEl.classList.contains('dark')?'dark':'light');
      iL.classList.toggle('hidden', !htmlEl.classList.contains('dark'));
      iD.classList.toggle('hidden', htmlEl.classList.contains('dark'));
    };
    (()=>{
      const t = localStorage.getItem('theme');
      if(t==='dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        htmlEl.classList.add('dark');
      }
      iL.classList.toggle('hidden', !htmlEl.classList.contains('dark'));
      iD.classList.toggle('hidden', htmlEl.classList.contains('dark'));
    })();

    // Mock send message
    document.getElementById('send-btn').onclick = () => {
      const input = document.getElementById('message-input'),
            text = input.value.trim();
      if (!text) return;
      const chat = document.getElementById('chat-window'),
            msg = document.createElement('div');
      msg.className = 'flex items-start space-x-3 justify-end';
      msg.innerHTML = `
        <div class="text-right">
          <p class="bg-indigo-600 text-white p-3 rounded-lg">${text}</p>
          <span class="text-xs text-gray-500 dark:text-gray-400">Now</span>
        </div>
        <img src="https://via.placeholder.com/32" class="w-8 h-8 rounded-full" alt="Me"/>
      `;
      chat.appendChild(msg);
      chat.scrollTop = chat.scrollHeight;
      input.value = '';
    };

    // Mock schedule form
    document.getElementById('schedule-form').onsubmit = e => {
      e.preventDefault();
      alert('Interview invite sent!');
      e.target.reset();
    };
  </script>
</body>
</html>
